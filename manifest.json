{
  "manifest_version": 3,
  "name": "TritonSched",
  "version": "1.0.0",
  "description": "Calendar schedule builder and planning tool for UC San Diego students using TSS.",

  "icons": {
    "48": "logo48.png",
    "128": "logo128.png"
  },

  "action": {
    "default_icon": {
      "48": "logo48.png",
      "128": "logo128.png"
    },
    "default_title": "TritonSched"
  },

  "content_scripts": [
    {
      "matches": ["https://*.ucsd.edu/*"],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["logo128.png", "logo48.png"],
      "matches": ["https://*.ucsd.edu/*"]
    }
  ]
}